#!/bin/bash

########################################
# LSS NETWORK TOOLKIT
########################################

GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

LOGFILE="/tmp/lss-netinfo-session.log"
> "$LOGFILE"

########################################
# Dependency Check
########################################

check_dependency() {

if command -v "$1" >/dev/null 2>&1
then
printf "%-15s ${GREEN}PASS${NC}\n" "$1:"
return 0
else
printf "%-15s ${RED}FAIL${NC}\n" "$1:"
return 1
fi

}

install_pkg() {

PKG=$1

read -p "$PKG missing. Install now? (y/n): " ans

if [[ "$ans" == "y" || "$ans" == "Y" ]]
then
brew install "$PKG"
else
echo "$PKG required to continue."
exit 1
fi

}

run_dependency_check() {

echo ""
echo "================================="
echo "Dependency Check"
echo "================================="

check_dependency brew
BREW_STATUS=$?

check_dependency nmap
NMAP_STATUS=$?

check_dependency arp-scan
ARP_STATUS=$?

check_dependency speedtest
SPEED_STATUS=$?

echo ""

if [ $BREW_STATUS -ne 0 ]; then
echo "Homebrew missing."
read -p "Install Homebrew? (y/n): " ans
if [[ "$ans" == "y" || "$ans" == "Y" ]]
then
/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
else
exit 1
fi
fi

if [ $NMAP_STATUS -ne 0 ]; then
install_pkg nmap
fi

if [ $ARP_STATUS -ne 0 ]; then
install_pkg arp-scan
fi

if [ $SPEED_STATUS -ne 0 ]; then
install_pkg speedtest-cli
fi

}

########################################

log_run() {
"$@" | tee -a "$LOGFILE"
}

########################################

get_interfaces() {

networksetup -listallhardwareports | awk '
/Hardware Port/ {port=$0}
/Device/ {print port "|" $2}
'

}

########################################

select_interface() {

while true
do

echo ""
echo "================================="
echo " Select Network Interface"
echo "================================="
echo ""

IFS=$'\n'
interfaces=($(get_interfaces))

i=1
for iface in "${interfaces[@]}"
do
PORT=$(echo "$iface" | cut -d'|' -f1 | sed 's/Hardware Port: //')
DEV=$(echo "$iface" | cut -d'|' -f2)
echo "$i) $PORT ($DEV)"
((i++))
done

echo ""
echo "0) Exit"
echo ""

read -p "Select interface: " choice

if [ "$choice" == "0" ]; then
exit
fi

IF=$(echo "${interfaces[$((choice-1))]}" | cut -d'|' -f2)

if [ -n "$IF" ]; then
echo ""
echo "Selected interface: $IF"
echo ""
break
fi

echo "Invalid option"

done

}

########################################

get_gateway() {
ipconfig getpacket "$IF" | awk -F"[{}]" '/router/ {print $2}'
}

get_network() {
ipconfig getifaddr "$IF" | awk -F. '{print $1"."$2"."$3".0/24"}'
}

########################################

interface_info() {

printf "\nInterface: %s\nIP: %s\nSubnet: %s\nGateway: %s\nDNS: %s\nDHCP: %s\n\n" \
$IF \
$(ipconfig getifaddr $IF) \
$(ipconfig getoption $IF subnet_mask) \
$(get_gateway) \
"$(ipconfig getpacket $IF | awk -F"[{}]" '/domain_name_server/ {print $2}')" \
$(ipconfig getoption $IF server_identifier) | tee -a "$LOGFILE"

}

########################################

discover_devices() {

echo "" | tee -a "$LOGFILE"
echo "Discovering devices..." | tee -a "$LOGFILE"
echo "" | tee -a "$LOGFILE"

sudo arp-scan --interface=$IF --localnet | tee -a "$LOGFILE"

}

########################################

gateway_ports() {

GW=$(get_gateway)

echo "" | tee -a "$LOGFILE"
echo "Gateway: $GW" | tee -a "$LOGFILE"
echo "" | tee -a "$LOGFILE"

sudo nmap -Pn -T4 --open $GW | tee -a "$LOGFILE"

}

########################################

gateway_fingerprint() {

GW=$(get_gateway)

echo "" | tee -a "$LOGFILE"
echo "Gateway: $GW" | tee -a "$LOGFILE"
echo "" | tee -a "$LOGFILE"

sudo nmap -Pn -A -T4 --top-ports 100 $GW | tee -a "$LOGFILE"

}

########################################

rogue_dhcp() {

echo "" | tee -a "$LOGFILE"
echo "Scanning for rogue DHCP servers..." | tee -a "$LOGFILE"
echo "" | tee -a "$LOGFILE"

sudo nmap --script broadcast-dhcp-discover -e $IF 2>/dev/null | tee -a "$LOGFILE"

}

########################################

network_map() {

NET=$(get_network)

echo "" | tee -a "$LOGFILE"
echo "Network: $NET" | tee -a "$LOGFILE"
echo "" | tee -a "$LOGFILE"

sudo nmap -sn -O -sV $NET | tee -a "$LOGFILE"

}

########################################

find_web_interfaces() {

NET=$(get_network)

echo "" | tee -a "$LOGFILE"
echo "Scanning for web admin interfaces..." | tee -a "$LOGFILE"
echo "" | tee -a "$LOGFILE"

sudo nmap -p 80,443,8080,8443 --open $NET | tee -a "$LOGFILE"

}

########################################

find_remote_access() {

NET=$(get_network)

echo "" | tee -a "$LOGFILE"
echo "Scanning for remote access services..." | tee -a "$LOGFILE"
echo "" | tee -a "$LOGFILE"

sudo nmap -p 22,3389,5900 --open $NET | tee -a "$LOGFILE"

}

########################################

gateway_health() {

GW=$(get_gateway)

echo "" | tee -a "$LOGFILE"
echo "Testing gateway health..." | tee -a "$LOGFILE"
echo "" | tee -a "$LOGFILE"

ping -c 10 $GW | tee -a "$LOGFILE"

}

########################################

speed_test() {

echo "" | tee -a "$LOGFILE"
echo "Running internet speed test..." | tee -a "$LOGFILE"
echo "" | tee -a "$LOGFILE"

speedtest | tee -a "$LOGFILE"

}

########################################

quick_audit() {

echo "" | tee -a "$LOGFILE"
echo "=================================" | tee -a "$LOGFILE"
echo " LSS NETWORK QUICK AUDIT" | tee -a "$LOGFILE"
echo "=================================" | tee -a "$LOGFILE"

interface_info
gateway_ports
gateway_fingerprint
discover_devices
rogue_dhcp

}

########################################

export_report() {

DATE=$(date "+%Y-%m-%d_%H-%M-%S")
DEST="$HOME/Desktop/LSS-NetInfo-Export-$DATE.txt"

cp "$LOGFILE" "$DEST"

echo ""
echo "Export saved to:"
echo "$DEST"
echo ""

}

########################################

show_menu() {

echo ""
echo "================================="
echo "        LSS NETWORK TOOLKIT"
echo "================================="
echo ""

echo "1) Interface Network Info"
echo "2) Discover Devices"
echo "3) Gateway Port Scan"
echo "4) Gateway Fingerprint"
echo "5) Rogue DHCP Detection"
echo "6) Network Map"
echo "7) Find Web Admin Interfaces"
echo "8) Find Remote Access Services"
echo "9) Gateway Health Test"
echo "10) Internet Speed Test"
echo "11) Quick Network Audit"
echo ""
echo "0) Exit"
echo ""

read -p "Select option: " opt

case $opt in

1) interface_info ;;
2) discover_devices ;;
3) gateway_ports ;;
4) gateway_fingerprint ;;
5) rogue_dhcp ;;
6) network_map ;;
7) find_web_interfaces ;;
8) find_remote_access ;;
9) gateway_health ;;
10) speed_test ;;
11) quick_audit ;;

0)
read -p "Export session report to Desktop? (y/n): " exp
if [[ "$exp" == "y" || "$exp" == "Y" ]]; then
export_report
fi
exit
;;

*) echo "Invalid option" ;;

esac

}

########################################

run_dependency_check
select_interface

while true
do
show_menu
done
